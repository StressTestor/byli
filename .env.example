# --- Supabase ---
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- TwitterAPI.io (Article Ingestion) ---
# Sign up: https://twitterapi.io -> Dashboard -> Copy API Key
# Pay-as-you-go: 0.15 per 1K tweets, ~0.015 per article fetch
# No monthly commitment, no approval process
TWITTERAPI_IO_KEY=your-twitterapi-io-key-here

# --- Vercel Cron Secret ---
# Generate: openssl rand -base64 32
# Used to authenticate cron job requests to /api/ingest
CRON_SECRET=your-cron-secret-here

# --- X OAuth 2.0 (for Author Claiming) ---
# Get from: https://developer.x.com/en/portal/projects-and-apps
# Configure callback URL: https://YOUR_DOMAIN/auth/callback
# In Supabase: Authentication > Providers > Twitter > Enable
TWITTER_CLIENT_ID=your-x-client-id
TWITTER_CLIENT_SECRET=your-x-client-secret

# --- Monetag Ads (Revenue) ---
# Get from: https://monetag.com -> Sites -> Add Site -> Copy zone IDs
# Toggle ads on/off instantly. Set to false for acquisition demos.
NEXT_PUBLIC_MONETAG_ENABLED=false
NEXT_PUBLIC_MONETAG_SITE_ID=your-monetag-site-id
NEXT_PUBLIC_MONETAG_NATIVE_ZONE=your-native-zone-id
NEXT_PUBLIC_MONETAG_BANNER_ZONE=your-banner-zone-id
NEXT_PUBLIC_MONETAG_INTERSTITIAL_ZONE=your-interstitial-zone-id
NEXT_PUBLIC_FEED_AD_INTERVAL=6
